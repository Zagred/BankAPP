<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.MainPage"
             Title="Bank Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Bank Dashboard"
                           FontSize="30"
                           FontAttributes="Bold" />

                    <Label x:Name="WelcomeLabel"
                           Text="Welcome!"
                           FontSize="16"
                           FontAttributes="Italic"
                           Opacity="0.85" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Logout"
                        CornerRadius="12"
                        HeightRequest="42"
                        Clicked="OnLogoutClicked" />
            </Grid>

            <!-- ACCOUNTS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Text="Accounts"
                               FontSize="22"
                               FontAttributes="Bold" />

                        <Button Grid.Column="1"
                                Text="+ New"
                                CornerRadius="12"
                                HeightRequest="36"
                                Padding="8"
                                FontSize="12"
                                Clicked="OnCreateAccountClicked" />
                    </Grid>

                    <CollectionView x:Name="AccountsCollection"
                                    SelectionMode="None"
                                    HeightRequest="160">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="4">

                                        <Label Text="{Binding Iban}"
                                               FontAttributes="Bold"
                                               FontSize="16" />

                                        <Label Text="{Binding Balance, StringFormat='Balance: {0:F2}'}" />

                                        <Label Text="{Binding Currency}"
                                               Opacity="0.7" />

                                        <Label Text="{Binding Role}"
                                               Opacity="0.7" />

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- DASHBOARD CARDS -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Accounts" FontAttributes="Bold" FontSize="18" />
                        <Label Text="Total balance" Opacity="0.7" />
                        <Label x:Name="BalanceLabel" Text="0.00" FontSize="28" FontAttributes="Bold" />
                        <Label x:Name="AccountCountLabel" Text="0 accounts" Opacity="0.7" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Transfers" FontAttributes="Bold" FontSize="18" />
                        <Label x:Name="TransferCountLabel" Text="0 transfers" Opacity="0.7" />
                        <Label x:Name="LastTransferLabel" Text="Last transfer: -" Opacity="0.7" />
                        <Button Text="Transfer" CornerRadius="12" Clicked="OnTransferClicked" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Payments" FontAttributes="Bold" FontSize="18" />
                        <Label x:Name="PaymentsTotalLabel" Text="Spent: 0.00" Opacity="0.7" />
                        <Label x:Name="IncomeLabel" Text="Income: 0.00" Opacity="0.7" />
                        <Button Text="Transfer" CornerRadius="12" Clicked="OnTransferClicked" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- SPENDING CHART -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Spending last 7 days" FontSize="22" FontAttributes="Bold" />
                    <CollectionView x:Name="ChartCollectionView"
                                    ItemsLayout="HorizontalList"
                                    SelectionMode="None"
                                    HeightRequest="170">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                    <BoxView HeightRequest="{Binding Height}" WidthRequest="24" Color="#4C8CFF" CornerRadius="12" />
                                    <Label Text="{Binding DayLabel}" FontSize="12" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding AmountText}" FontSize="12" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- PAYMENTS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Payments" FontSize="22" FontAttributes="Bold" />

                    <Picker x:Name="FilterPicker"
                            Title="Filter by type"
                            SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>all</x:String>
                                <x:String>card_payment</x:String>
                                <x:String>transfer</x:String>
                                <x:String>cash_withdrawal</x:String>
                                <x:String>deposit</x:String>
                                <x:String>fee</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <CollectionView x:Name="TransactionsCollection"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout>
                                                <Label Text="{Binding MovementTypeDisplay}"
                                                       FontAttributes="Bold"
                                                       FontSize="18"/>
                                                <Label Text="{Binding Category}"
                                                       FontSize="12"
                                                       Opacity="0.7" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="1"
                                                   Text="{Binding AmountText}"
                                                   FontSize="16">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding IsExpense}"
                                                                 Value="True">
                                                        <Setter Property="TextColor" Value="Red" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding IsExpense}"
                                                                 Value="False">
                                                        <Setter Property="TextColor" Value="Green" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>

                                        <Label Text="{Binding Description}" />
                                        <Label Text="{Binding Status}" Opacity="0.8" />
                                        <Label Text="{Binding Currency}" Opacity="0.8" />
                                        <Label Text="{Binding ReferenceNumber}" Opacity="0.8" />
                                        <Label Text="{Binding MovementDateTime, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                               Opacity="0.8" />

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>