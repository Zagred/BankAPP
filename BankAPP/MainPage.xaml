<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.MainPage"
             Title="Finance Tracker">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Finance Tracker"
                           FontSize="30"
                           FontAttributes="Bold" />

                    <Label x:Name="WelcomeLabel"
                           Text="Welcome!"
                           FontSize="16"
                           FontAttributes="Italic"
                           Opacity="0.85" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Logout"
                        CornerRadius="12"
                        HeightRequest="42"
                        Clicked="OnLogoutClicked" />
            </Grid>

            <Label x:Name="BudgetWarningLabel"
                   Text="Warning: Budget exceeded!"
                   TextColor="Red"
                   FontSize="16"
                   FontAttributes="Bold"
                   IsVisible="False" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <Frame Grid.Row="0" Grid.Column="0" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Balance" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="BalanceLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Income" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="IncomeLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Expense" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="ExpenseLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Quick Actions"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
                                Text="Add Transaction"
                                CornerRadius="12"
                                Clicked="OnOpenAddTransactionPageClicked" />

                        <Button Grid.Row="0" Grid.Column="1"
                                Text="Add Budget"
                                CornerRadius="12"
                                Clicked="OnOpenAddBudgetPageClicked" />

                        <Button Grid.Row="1" Grid.Column="0"
                                Text="Import JSON"
                                CornerRadius="12"
                                Clicked="OnImportJsonClicked" />

                        <Button Grid.Row="1" Grid.Column="1"
                                Text="Import XML"
                                CornerRadius="12"
                                Clicked="OnImportXmlClicked" />

                        <Button Grid.Row="2" Grid.Column="0"
                                Text="Export JSON"
                                CornerRadius="12"
                                Clicked="OnExportJsonClicked" />

                        <Button Grid.Row="2" Grid.Column="1"
                                Text="Export XML"
                                CornerRadius="12"
                                Clicked="OnExportXmlClicked" />
                    </Grid>

                    <Button Text="Refresh"
                            CornerRadius="12"
                            Clicked="OnRefreshClicked" />

                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Expense Chart"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <CollectionView x:Name="ExpenseChartCollection"
                                    SelectionMode="None"
                                    HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="{Binding Category}"
                                                   FontAttributes="Bold"
                                                   FontSize="16" />

                                            <Label Grid.Column="1"
                                                   Text="{Binding TotalAmount, StringFormat='{0:F2}'}"
                                                   FontSize="16" />

                                            <Label Grid.Column="2"
                                                   Text="{Binding PercentageText}"
                                                   FontSize="14" />
                                        </Grid>

                                        <ProgressBar Progress="{Binding Percentage}"
                                                     HeightRequest="12" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Transactions"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <Picker x:Name="FilterPicker"
                            Title="Filter by type"
                            SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>all</x:String>
                                <x:String>income</x:String>
                                <x:String>expense</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <CollectionView x:Name="TransactionsCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnTransactionSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Category}"
                                                   FontAttributes="Bold"
                                                   FontSize="18"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat='{0:F2}'}"
                                                   FontSize="16"/>
                                        </Grid>

                                        <Label Text="{Binding Description}" />
                                        <Label Text="{Binding Type}" Opacity="0.8" />
                                        <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                               Opacity="0.8" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Expenses by Category"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <CollectionView x:Name="CategorySummaryCollection"
                                    SelectionMode="None"
                                    HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Category}"
                                               FontAttributes="Bold"
                                               FontSize="16" />
                                        <Label Grid.Column="1"
                                               Text="{Binding TotalAmount, StringFormat='{0:F2}'}"
                                               FontSize="16" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Budgets"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <CollectionView x:Name="BudgetSummaryCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnBudgetSelected"
                                    HeightRequest="220">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Category}"
                                               FontAttributes="Bold"
                                               FontSize="16" />
                                        <Label Text="{Binding LimitAmount, StringFormat='Budget: {0:F2}'}" />
                                        <Label Text="{Binding SpentAmount, StringFormat='Spent: {0:F2}'}" />
                                        <Label Text="{Binding RemainingAmount, StringFormat='Remaining: {0:F2}'}" />
                                        <Label Text="{Binding IsExceeded, StringFormat='Exceeded: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>