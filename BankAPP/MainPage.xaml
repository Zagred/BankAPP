<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.MainPage"
             Title="Bank Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Bank Dashboard"
                           FontSize="30"
                           FontAttributes="Bold" />

                    <Label x:Name="WelcomeLabel"
                           Text="Welcome!"
                           FontSize="16"
                           FontAttributes="Italic"
                           Opacity="0.85" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Logout"
                        CornerRadius="12"
                        HeightRequest="42"
                        Clicked="OnLogoutClicked" />
            </Grid>

            <!-- ACCOUNTS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Accounts"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <CollectionView x:Name="AccountsCollection"
                                    SelectionMode="None"
                                    HeightRequest="160">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="4">

                                        <Label Text="{Binding Iban}"
                                               FontAttributes="Bold"
                                               FontSize="16" />

                                        <Label Text="{Binding Balance, StringFormat='Balance: {0:F2}'}" />

                                        <Label Text="{Binding Currency}"
                                               Opacity="0.7" />

                                        <Label Text="{Binding Role}"
                                               Opacity="0.7" />

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- SUMMARY -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <Frame Grid.Row="0" Grid.Column="0" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Balance" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="BalanceLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Credit" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="IncomeLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Debit" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="ExpenseLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- ACTIONS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Quick Actions"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
            Text="Add Movement"
            CornerRadius="12"
            Clicked="OnAddMovementClicked" />

                        <Button Grid.Row="0" Grid.Column="1"
            Text="Transfer"
            CornerRadius="12"
            Clicked="OnTransferClicked" />

                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
            Text="Refresh"
            CornerRadius="12"
            Clicked="OnRefreshClicked" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- MOVEMENTS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Movements"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <Picker x:Name="FilterPicker"
                            Title="Filter by type"
                            SelectedIndexChanged="OnFilterChanged">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>all</x:String>
                                <x:String>card_payment</x:String>
                                <x:String>transfer</x:String>
                                <x:String>cash_withdrawal</x:String>
                                <x:String>deposit</x:String>
                                <x:String>fee</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <CollectionView x:Name="TransactionsCollection"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="6">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding MovementType}"
                                                   FontAttributes="Bold"
                                                   FontSize="18"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat='{0:F2}'}"
                                                   FontSize="16"/>
                                        </Grid>

                                        <Label Text="{Binding Description}" />
                                        <Label Text="{Binding Status}" Opacity="0.8" />
                                        <Label Text="{Binding Currency}" Opacity="0.8" />
                                        <Label Text="{Binding ReferenceNumber}" Opacity="0.8" />
                                        <Label Text="{Binding MovementDateTime, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                               Opacity="0.8" />

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>