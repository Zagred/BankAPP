<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.RegisterPage"
             Title="Register"
             BackgroundColor="{StaticResource PageBg}">

    <ContentPage.Content>
        <OnIdiom x:TypeArguments="View">

            <!-- ══════════════════════════════════
                 ДЕСКТОП layout
            ══════════════════════════════════ -->
            <OnIdiom.Desktop>
                <Grid ColumnDefinitions="*,420" RowDefinitions="*">

                    <Grid Grid.Column="0"
                          BackgroundColor="{StaticResource NavyDeep}"
                          Padding="52,48">
                        <Ellipse Fill="#07FFFFFF" WidthRequest="300" HeightRequest="300"
                                 HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-70,-70" />
                        <Ellipse Fill="#05FFFFFF" WidthRequest="200" HeightRequest="200"
                                 HorizontalOptions="Start" VerticalOptions="Start" Margin="-50,-50,0,0" />
                        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                            <HorizontalStackLayout Spacing="12" Margin="0,0,0,52">
                                <Border BackgroundColor="{StaticResource BrandRed}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 10"
                                        WidthRequest="44" HeightRequest="44" Padding="0">
                                    <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                          Stroke="White" StrokeThickness="1.8"
                                          StrokeLineCap="Round" StrokeLineJoin="Round"
                                          WidthRequest="22" HeightRequest="22" Aspect="Uniform"
                                          HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="BankApp" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                                    <Label Text="ДИГИТАЛНО БАНКИРАНЕ" FontSize="9" CharacterSpacing="0.8" TextColor="#66FFFFFF"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Label Text="Създайте акаунт&#10;за минути."
                                   FontSize="28" FontAttributes="Bold" TextColor="White"
                                   LineHeight="1.35" Margin="0,0,0,16"/>
                            <Label Text="Попълнете формата и получете достъп до всички функции на BankApp веднага."
                                   FontSize="13" TextColor="#77FFFFFF" LineHeight="1.65" Margin="0,0,0,40"/>
                            <VerticalStackLayout Spacing="14">
                                <HorizontalStackLayout Spacing="12">
                                    <BoxView Color="{StaticResource BrandRed}" WidthRequest="6" HeightRequest="6" CornerRadius="3" VerticalOptions="Center"/>
                                    <Label Text="Бърза и лесна регистрация" FontSize="12" TextColor="#77FFFFFF" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="12">
                                    <BoxView Color="{StaticResource BrandRed}" WidthRequest="6" HeightRequest="6" CornerRadius="3" VerticalOptions="Center"/>
                                    <Label Text="Сигурно съхранение на данните" FontSize="12" TextColor="#77FFFFFF" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="12">
                                    <BoxView Color="{StaticResource BrandRed}" WidthRequest="6" HeightRequest="6" CornerRadius="3" VerticalOptions="Center"/>
                                    <Label Text="Незабавен достъп след регистрация" FontSize="12" TextColor="#77FFFFFF" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <ScrollView Grid.Column="1" BackgroundColor="White">
                        <VerticalStackLayout Padding="40,0" VerticalOptions="Center" Spacing="0">
                            <Label Text="Нов акаунт" FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" Margin="0,48,0,4"/>
                            <Label Text="Попълнете всички полета, за да продължите"
                                   FontSize="13" TextColor="{StaticResource TextMuted}" Margin="0,0,0,32"/>
                            <Label Text="ПЪЛНО ИМЕ" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                                <Entry x:Name="NameEntry" Placeholder="Въведете пълното си име"
                                       PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="ПОТРЕБИТЕЛСКО ИМЕ" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                                <Entry x:Name="UsernameEntry" Placeholder="Изберете потребителско име"
                                       PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="ИМЕЙЛ АДРЕС" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                                <Entry x:Name="EmailEntry" Placeholder="example@email.com"
                                       PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" Keyboard="Email" BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="ЕГН" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                                <Entry x:Name="EgnEntry" Placeholder="10 цифри"
                                       PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" Keyboard="Numeric" MaxLength="10"
                                       BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="ПАРОЛА" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,28">
                                <Entry x:Name="PasswordEntry" Placeholder="Минимум 6 символа"
                                       PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                       IsPassword="True" FontSize="14" BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing" ReturnType="Done" VerticalOptions="Center"/>
                            </Border>
                            <Button Text="Създай акаунт" Style="{StaticResource PrimaryBtn}" Clicked="OnRegisterClicked"/>
                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,20,0,16">
                                <BoxView Grid.Column="0" Color="{StaticResource BorderColor}" HeightRequest="0.5" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="или" FontSize="11" TextColor="{StaticResource TextMuted}" Margin="14,0"/>
                                <BoxView Grid.Column="2" Color="{StaticResource BorderColor}" HeightRequest="0.5" VerticalOptions="Center"/>
                            </Grid>
                            <Button Text="Назад към вход" Style="{StaticResource OutlineBtn}" Clicked="OnGoToLoginClicked"/>
                            <Border BackgroundColor="#F8F9FC" StrokeThickness="0.5"
                                    Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8"
                                    Padding="14,11" Margin="0,20,0,48">
                                <HorizontalStackLayout Spacing="9">
                                    <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                          Fill="{StaticResource SuccessGreen}" WidthRequest="16" HeightRequest="16"
                                          Aspect="Uniform" VerticalOptions="Center"/>
                                    <Label Text="Данните ви са защитени и криптирани" FontSize="11"
                                           TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>
            </OnIdiom.Desktop>

            <!-- ══════════════════════════════════
                 МОБИЛЕН layout
            ══════════════════════════════════ -->
            <OnIdiom.Phone>
                <ScrollView BackgroundColor="{StaticResource NavyDeep}">
                    <Grid RowDefinitions="200,Auto">

                        <!-- Hero header -->
                        <Grid Grid.Row="0"
                              BackgroundColor="{StaticResource NavyDeep}"
                              Padding="28,48,28,24">
                            <Ellipse Fill="#08FFFFFF" WidthRequest="200" HeightRequest="200"
                                     HorizontalOptions="End" VerticalOptions="Start" Margin="0,-30,-30,0" />
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                                <Border BackgroundColor="{StaticResource BrandRed}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                        WidthRequest="64" HeightRequest="64" Padding="0"
                                        HorizontalOptions="Center">
                                    <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                          Stroke="White" StrokeThickness="1.8"
                                          StrokeLineCap="Round" StrokeLineJoin="Round"
                                          WidthRequest="30" HeightRequest="30" Aspect="Uniform"
                                          HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="BankApp" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="ДИГИТАЛНО БАНКИРАНЕ" FontSize="9" CharacterSpacing="0.8"
                                       TextColor="#66FFFFFF" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Floating card -->
                        <Border Grid.Row="1"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 28,28,0,0"
                                Padding="24,32,24,40">
                            <VerticalStackLayout Spacing="0">

                                <Label Text="Нов акаунт" FontSize="24" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                <Label Text="Попълнете всички полета, за да продължите"
                                       FontSize="13" TextColor="{StaticResource TextMuted}" Margin="0,0,0,24"/>

                                <Label Text="ПЪЛНО ИМЕ" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                    <Entry x:Name="NameEntryMobile" Placeholder="Въведете пълното си име"
                                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                           FontSize="14" BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                                </Border>

                                <Label Text="ПОТРЕБИТЕЛСКО ИМЕ" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                    <Entry x:Name="UsernameEntryMobile" Placeholder="Изберете потребителско име"
                                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                           FontSize="14" BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                                </Border>

                                <Label Text="ИМЕЙЛ АДРЕС" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                    <Entry x:Name="EmailEntryMobile" Placeholder="example@email.com"
                                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                           FontSize="14" Keyboard="Email" BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                                </Border>

                                <Label Text="ЕГН" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,14">
                                    <Entry x:Name="EgnEntryMobile" Placeholder="10 цифри"
                                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                           FontSize="14" Keyboard="Numeric" MaxLength="10"
                                           BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing" VerticalOptions="Center"/>
                                </Border>

                                <Label Text="ПАРОЛА" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,24">
                                    <Entry x:Name="PasswordEntryMobile" Placeholder="Минимум 6 символа"
                                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                                           IsPassword="True" FontSize="14" BackgroundColor="Transparent"
                                           ClearButtonVisibility="WhileEditing" ReturnType="Done" VerticalOptions="Center"/>
                                </Border>

                                <Button Text="Създай акаунт"
                                        Style="{StaticResource PrimaryBtn}"
                                        Clicked="OnRegisterClicked"/>

                                <Grid ColumnDefinitions="*,Auto,*" Margin="0,20,0,16">
                                    <BoxView Grid.Column="0" Color="{StaticResource BorderColor}" HeightRequest="0.5" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="или" FontSize="11" TextColor="{StaticResource TextMuted}" Margin="12,0"/>
                                    <BoxView Grid.Column="2" Color="{StaticResource BorderColor}" HeightRequest="0.5" VerticalOptions="Center"/>
                                </Grid>

                                <Button Text="Назад към вход"
                                        Style="{StaticResource OutlineBtn}"
                                        Clicked="OnGoToLoginClicked"/>

                                <Border BackgroundColor="#F8F9FC" StrokeThickness="0.5"
                                        Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8"
                                        Padding="14,11" Margin="0,20,0,0">
                                    <HorizontalStackLayout Spacing="9">
                                        <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                              Fill="{StaticResource SuccessGreen}" WidthRequest="16" HeightRequest="16"
                                              Aspect="Uniform" VerticalOptions="Center"/>
                                        <Label Text="Данните ви са защитени и криптирани" FontSize="11"
                                               TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </ScrollView>
            </OnIdiom.Phone>

        </OnIdiom>
    </ContentPage.Content>

</ContentPage>