<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.AddMovementPage"
             Title="Add Movement">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Add Movement"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Entry x:Name="AmountEntry"
                   Placeholder="Amount"
                   Keyboard="Numeric" />

            <Picker x:Name="TypePicker"
                    Title="Select movement type">
                <Picker.Items>
                    <x:String>deposit</x:String>
                    <x:String>transfer</x:String>
                    <x:String>card_payment</x:String>
                    <x:String>cash_withdrawal</x:String>
                    <x:String>fee</x:String>
                </Picker.Items>
            </Picker>

            <Entry x:Name="DescriptionEntry"
                   Placeholder="Description" />

            <Button Text="Add Movement"
                    Clicked="OnAddClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>