<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.AddMovementPage"
             Title="Add Movement"
             BackgroundColor="{StaticResource PageBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid BackgroundColor="{StaticResource NavyDeep}" Padding="20,48,20,28">
                <Ellipse Fill="#07FFFFFF" WidthRequest="160" HeightRequest="160"
                         HorizontalOptions="End" VerticalOptions="Start" Margin="0,-30,-30,0"/>
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="10" Margin="0,0,0,20">
                        <Border BackgroundColor="{StaticResource BrandRed}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="28" HeightRequest="28" Padding="0">
                            <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                  Stroke="White" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="14" HeightRequest="14" Aspect="Uniform"
                                  HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="BankApp" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                    </HorizontalStackLayout>
                    <Label Text="Добави движение" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Ръчно добавяне на транзакция"
                           FontSize="13" TextColor="#77FFFFFF"/>
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="24,28,24,40" Margin="0,-16,0,0">
                <VerticalStackLayout Spacing="0">

                    <Label Text="СМЕТКА" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" HeightRequest="46" Margin="0,0,0,16">
                        <Picker x:Name="AccountPicker"
                                Title="Избери сметка"
                                ItemDisplayBinding="{Binding DisplayText}"
                                BackgroundColor="Transparent" FontSize="13"
                                VerticalOptions="Center"/>
                    </Border>

                    <Label Text="СУМА (BGN)" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                        <Entry x:Name="AmountEntry"
                               Placeholder="0,00"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Numeric" FontSize="14"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Text="ВИД ДВИЖЕНИЕ" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" HeightRequest="46" Margin="0,0,0,16">
                        <Picker x:Name="TypePicker"
                                Title="Избери вид"
                                ItemDisplayBinding="{Binding DisplayName}"
                                BackgroundColor="Transparent" FontSize="13"
                                VerticalOptions="Center"/>
                    </Border>

                    <Label Text="ОПИСАНИЕ" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,28">
                        <Entry x:Name="DescriptionEntry"
                               Placeholder="Описание"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="14" BackgroundColor="Transparent"
                               ReturnType="Done"
                               VerticalOptions="Center"/>
                    </Border>

                    <Button Text="Добави движение"
                            Style="{StaticResource PrimaryBtn}"
                            Clicked="OnAddClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>