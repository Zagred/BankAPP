<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.AccountsPage"
             Title="Accounts"
             BackgroundColor="{StaticResource PageBg}">

    <ContentPage.Content>
        <OnIdiom x:TypeArguments="View">

            <!-- ══════════════════════════════════
                 ДЕСКТОП layout
            ══════════════════════════════════ -->
            <OnIdiom.Desktop>
                <Grid RowDefinitions="52,*" ColumnDefinitions="220,*">

                    <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                          BackgroundColor="{StaticResource NavyDeep}"
                          RowDefinitions="Auto,*,Auto">
                        <HorizontalStackLayout Grid.Row="0" Spacing="10" Padding="20,22,20,20">
                            <Border BackgroundColor="{StaticResource BrandRed}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    WidthRequest="34" HeightRequest="34" Padding="0">
                                <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                      Stroke="White" StrokeThickness="1.6"
                                      StrokeLineCap="Round" StrokeLineJoin="Round"
                                      WidthRequest="18" HeightRequest="18" Aspect="Uniform"
                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                <Label Text="BankApp" FontSize="15" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="ДИГИТАЛНО БАНКИРАНЕ" FontSize="8" CharacterSpacing="0.6" TextColor="#55FFFFFF"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Padding="10,16" Spacing="2">
                            <Label Text="ГЛАВНО МЕНЮ" FontSize="9" CharacterSpacing="0.8"
                                   TextColor="#44FFFFFF" Margin="10,0,0,8" TextTransform="Uppercase"/>
                            <Border BackgroundColor="{StaticResource BrandRed}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 7" Padding="10,9">
                                <HorizontalStackLayout Spacing="10">
                                    <Path Data="M3 9 L12 2 L21 9 L21 21 L5 21 Z M9 21 L9 12 L15 12 L15 21"
                                          Stroke="White" StrokeThickness="1.6"
                                          StrokeLineCap="Round" StrokeLineJoin="Round"
                                          WidthRequest="17" HeightRequest="17" Aspect="Uniform"
                                          VerticalOptions="Center"/>
                                    <Label Text="Сметки" FontSize="13" TextColor="White" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Button Text="Преводи" BackgroundColor="Transparent" TextColor="#77FFFFFF"
                                    BorderWidth="0" CornerRadius="7" FontSize="13" HeightRequest="42"
                                    HorizontalOptions="Fill" Padding="10,0" Clicked="OnNavigateToTransfers"/>
                            <Button Text="Плащания" BackgroundColor="Transparent" TextColor="#77FFFFFF"
                                    BorderWidth="0" CornerRadius="7" FontSize="13" HeightRequest="42"
                                    HorizontalOptions="Fill" Padding="10,0" Clicked="OnNavigateToPayments"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="2" Padding="10,14">
                            <BoxView HeightRequest="0.5" Color="#33FFFFFF" Margin="0,0,0,12"/>
                            <HorizontalStackLayout Spacing="10" Padding="10,0">
                                <Border BackgroundColor="{StaticResource BrandRed}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                        WidthRequest="32" HeightRequest="32">
                                    <Label x:Name="AvatarLabel" Text="?" FontSize="13" FontAttributes="Bold"
                                           TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                    <Label x:Name="SidebarUsernameLabel" Text="—" FontSize="12"
                                           FontAttributes="Bold" TextColor="#CCFFFFff"/>
                                    <Label Text="Стандартен акаунт" FontSize="10" TextColor="#55FFFFFF"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid Grid.Row="0" Grid.Column="1" BackgroundColor="White"
                          ColumnDefinitions="*,Auto,Auto" Padding="24,0" ColumnSpacing="10">
                        <Label Grid.Column="0" x:Name="WelcomeLabel" Text="Моите сметки"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="#F3F4F6"
                                StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 6" Padding="12,5">
                            <Label Text="17 май 2026" FontSize="11"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                        </Border>
                        <Button Grid.Column="2" Text="Изход" BackgroundColor="Transparent"
                                TextColor="{StaticResource TextMuted}" BorderColor="{StaticResource BorderColor}"
                                BorderWidth="1" CornerRadius="7" FontSize="12" FontAttributes="Bold"
                                HeightRequest="34" Padding="14,0" Clicked="OnLogoutClicked"/>
                    </Grid>

                    <ScrollView Grid.Row="1" Grid.Column="1">
                        <VerticalStackLayout Padding="24" Spacing="14">
                            <Border BackgroundColor="{StaticResource Navy}" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12" Padding="24,20">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                                        <Label Text="Общ баланс по всички сметки" FontSize="11" TextColor="#77FFFFFF"/>
                                        <Label x:Name="BalanceLabel" Text="0,00" Style="{StaticResource BalanceNumber}"/>
                                        <HorizontalStackLayout Spacing="10" Margin="0,8,0,0">
                                            <Button Text="Нов превод" Style="{StaticResource PrimaryBtn}"
                                                    HeightRequest="40" FontSize="13" Padding="16,0"
                                                    Clicked="OnTransferClicked"/>
                                            <Button Text="+ Нова сметка" BackgroundColor="#22FFFFFF"
                                                    TextColor="White" BorderWidth="0" CornerRadius="9"
                                                    HeightRequest="40" FontSize="13" Padding="16,0"
                                                    Clicked="OnCreateAccountClicked"/>
                                            <Button Text="Обнови" BackgroundColor="#22FFFFFF"
                                                    TextColor="White" BorderWidth="0" CornerRadius="9"
                                                    HeightRequest="40" FontSize="13" Padding="16,0"
                                                    Clicked="OnRefreshClicked"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="12"
                                                         HorizontalOptions="End" VerticalOptions="Center">
                                        <VerticalStackLayout Spacing="2" HorizontalOptions="End">
                                            <Label Text="Приходи" FontSize="10" TextColor="#55FFFFFF" HorizontalOptions="End"/>
                                            <Label x:Name="IncomeLabel" Text="0,00" FontSize="18" FontAttributes="Bold"
                                                   TextColor="#4ADE80" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Spacing="2" HorizontalOptions="End">
                                            <Label Text="Разходи" FontSize="10" TextColor="#55FFFFFF" HorizontalOptions="End"/>
                                            <Label x:Name="ExpenseLabel" Text="0,00" FontSize="18" FontAttributes="Bold"
                                                   TextColor="#F87171" HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="Всички сметки" Style="{StaticResource SectionTitle}"/>
                                            <Button Grid.Column="1" Text="+ Нова" Style="{StaticResource PrimaryBtn}"
                                                    HeightRequest="32" FontSize="11" Padding="10,0"
                                                    Clicked="OnCreateAccountClicked"/>
                                        </Grid>
                                        <CollectionView x:Name="AccountsCollection" SelectionMode="None">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" BackgroundColor="#F8F9FC"
                                                            StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                                            StrokeShape="RoundRectangle 8" Padding="14,12">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                                <Label Text="{Binding Iban}" FontSize="12" FontAttributes="Bold"
                                                                       TextColor="{StaticResource TextPrimary}"/>
                                                                <Label Text="{Binding Currency}" FontSize="11"
                                                                       TextColor="{StaticResource TextMuted}"/>
                                                            </VerticalStackLayout>
                                                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="2">
                                                                <Label Text="{Binding Balance, StringFormat='{0:F2}'}"
                                                                       FontSize="15" FontAttributes="Bold"
                                                                       TextColor="{StaticResource SuccessGreen}"
                                                                       HorizontalOptions="End"/>
                                                                <Label Text="{Binding Role}" FontSize="10"
                                                                       TextColor="{StaticResource TextMuted}"
                                                                       HorizontalOptions="End"/>
                                                            </VerticalStackLayout>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="14">
                                    <Border Style="{StaticResource Card}" Padding="18">
                                        <VerticalStackLayout Spacing="6">
                                            <Border BackgroundColor="#EEF2FA" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8" WidthRequest="34" HeightRequest="34"
                                                    HorizontalOptions="Start">
                                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                                      Fill="{StaticResource Navy}" WidthRequest="18" HeightRequest="18"
                                                      Aspect="Uniform" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Баланс" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextMuted}"
                                                   TextTransform="Uppercase" CharacterSpacing="0.4"/>
                                            <Label x:Name="BalanceLabelAlt" Text="0,00" FontSize="22" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"/>
                                            <Label Text="лв общо" FontSize="11" TextColor="{StaticResource TextMuted}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Style="{StaticResource Card}" Padding="18">
                                        <VerticalStackLayout Spacing="6">
                                            <Border BackgroundColor="{StaticResource SuccessGreenBg}" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8" WidthRequest="34" HeightRequest="34"
                                                    HorizontalOptions="Start">
                                                <Path Data="M7 17l9.2-9.2M17 17V7H7" Stroke="{StaticResource SuccessGreen}"
                                                      StrokeThickness="1.8" StrokeLineCap="Round" StrokeLineJoin="Round"
                                                      WidthRequest="18" HeightRequest="18" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Приходи" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextMuted}"
                                                   TextTransform="Uppercase" CharacterSpacing="0.4"/>
                                            <Label x:Name="IncomeLabelAlt" Text="0,00" FontSize="22" FontAttributes="Bold"
                                                   TextColor="{StaticResource SuccessGreen}"/>
                                            <Label Text="лв този месец" FontSize="11" TextColor="{StaticResource TextMuted}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Style="{StaticResource Card}" Padding="18">
                                        <VerticalStackLayout Spacing="6">
                                            <Border BackgroundColor="{StaticResource BrandRedLight}" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8" WidthRequest="34" HeightRequest="34"
                                                    HorizontalOptions="Start">
                                                <Path Data="M7 7l9.2 9.2M7 17V7h10" Stroke="{StaticResource BrandRed}"
                                                      StrokeThickness="1.8" StrokeLineCap="Round" StrokeLineJoin="Round"
                                                      WidthRequest="18" HeightRequest="18" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Разходи" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextMuted}"
                                                   TextTransform="Uppercase" CharacterSpacing="0.4"/>
                                            <Label x:Name="ExpenseLabelAlt" Text="0,00" FontSize="22" FontAttributes="Bold"
                                                   TextColor="{StaticResource BrandRed}"/>
                                            <Label Text="лв този месец" FontSize="11" TextColor="{StaticResource TextMuted}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>
            </OnIdiom.Desktop>

            <!-- ══════════════════════════════════
                 МОБИЛЕН layout
            ══════════════════════════════════ -->
            <OnIdiom.Phone>
                <Grid RowDefinitions="*,60" BackgroundColor="{StaticResource PageBg}">

                    <ScrollView Grid.Row="0">
                        <VerticalStackLayout Spacing="0">

                            <!-- Mobile Header Hero -->
                            <Grid BackgroundColor="{StaticResource NavyDeep}" Padding="20,48,20,24">
                                <Ellipse Fill="#07FFFFFF" WidthRequest="200" HeightRequest="200"
                                         HorizontalOptions="End" VerticalOptions="Start"
                                         Margin="0,-40,-40,0"/>
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                            <Border BackgroundColor="{StaticResource BrandRed}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                    WidthRequest="28" HeightRequest="28" Padding="0">
                                                <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                                      Stroke="White" StrokeThickness="1.6"
                                                      StrokeLineCap="Round" StrokeLineJoin="Round"
                                                      WidthRequest="14" HeightRequest="14" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="BankApp" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                                        </HorizontalStackLayout>
                                        <Border Grid.Column="1" BackgroundColor="{StaticResource BrandRed}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 16"
                                                WidthRequest="34" HeightRequest="34">
                                            <Label x:Name="AvatarLabelM" Text="?"
                                                   FontSize="13" FontAttributes="Bold" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                    <Label x:Name="WelcomeLabelM" Text="Добро утро,"
                                           FontSize="13" TextColor="#77FFFFFF" Margin="0,0,0,2"/>
                                    <Label x:Name="UsernameLabelM" Text="—"
                                           FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,16"/>
                                    <Label Text="Общ баланс" FontSize="11" TextColor="#77FFFFFF" Margin="0,0,0,4"/>
                                    <Label x:Name="BalanceLabelM" Text="0,00"
                                           FontSize="32" FontAttributes="Bold" TextColor="White" Margin="0,0,0,16"/>
                                    <!-- Quick actions -->
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="6">
                                            <Border BackgroundColor="{StaticResource BrandRed}"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    WidthRequest="46" HeightRequest="46" HorizontalOptions="Center">
                                                <Path Data="M22 2 L11 13 M22 2 L15 22 L11 13 L2 9 Z"
                                                      Stroke="White" StrokeThickness="1.6"
                                                      StrokeLineCap="Round" StrokeLineJoin="Round"
                                                      WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Превод" FontSize="10" TextColor="#77FFFFFF" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="6">
                                            <Border BackgroundColor="#22FFFFFF"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    WidthRequest="46" HeightRequest="46" HorizontalOptions="Center">
                                                <Path Data="M12 5 L12 19 M5 12 L19 12"
                                                      Stroke="White" StrokeThickness="1.8"
                                                      StrokeLineCap="Round"
                                                      WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Нова сметка" FontSize="10" TextColor="#77FFFFFF" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="6">
                                            <Border BackgroundColor="#22FFFFFF"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    WidthRequest="46" HeightRequest="46" HorizontalOptions="Center">
                                                <Path Data="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                                      Stroke="White" StrokeThickness="1.6"
                                                      StrokeLineCap="Round" StrokeLineJoin="Round"
                                                      WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Карти" FontSize="10" TextColor="#77FFFFFF" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="6">
                                            <Border BackgroundColor="#22FFFFFF"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    WidthRequest="46" HeightRequest="46" HorizontalOptions="Center">
                                                <Path Data="M3 12 A9 9 0 1 0 12 3"
                                                      Stroke="White" StrokeThickness="1.8"
                                                      StrokeLineCap="Round"
                                                      WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                                                      HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="Обнови" FontSize="10" TextColor="#77FFFFFF" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Stats row -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="16,14,16,0">
                                <Border Grid.Column="0" BackgroundColor="White"
                                        StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                        StrokeShape="RoundRectangle 10" Padding="14">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="ПРИХОДИ" FontSize="10" FontAttributes="Bold"
                                               TextColor="{StaticResource TextMuted}" CharacterSpacing="0.4"/>
                                        <Label x:Name="IncomeLabelM" Text="0,00"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource SuccessGreen}"/>
                                        <Label Text="лв този месец" FontSize="10" TextColor="{StaticResource TextMuted}"/>
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="White"
                                        StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                        StrokeShape="RoundRectangle 10" Padding="14">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="РАЗХОДИ" FontSize="10" FontAttributes="Bold"
                                               TextColor="{StaticResource TextMuted}" CharacterSpacing="0.4"/>
                                        <Label x:Name="ExpenseLabelM" Text="0,00"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource BrandRed}"/>
                                        <Label Text="лв този месец" FontSize="10" TextColor="{StaticResource TextMuted}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <!-- Accounts list -->
                            <VerticalStackLayout Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                    <Label Grid.Column="0" Text="Всички сметки"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <Button Grid.Column="1" Text="+ Нова"
                                            Style="{StaticResource PrimaryBtn}"
                                            HeightRequest="32" FontSize="11" Padding="10,0"
                                            Clicked="OnCreateAccountClicked"/>
                                </Grid>
                                <CollectionView x:Name="AccountsCollectionMobile" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" BackgroundColor="White"
                                                    StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                                    StrokeShape="RoundRectangle 10" Padding="14,12">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Border Grid.Column="0" BackgroundColor="#EEF2FA"
                                                            StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                            WidthRequest="36" HeightRequest="36">
                                                        <Path Data="M21 4 L3 4 L3 20 L21 20 Z M3 10 L21 10"
                                                              Stroke="{StaticResource Navy}" StrokeThickness="1.4"
                                                              StrokeLineCap="Round"
                                                              WidthRequest="16" HeightRequest="16" Aspect="Uniform"
                                                              HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                        <Label Text="{Binding Iban}" FontSize="11" FontAttributes="Bold"
                                                               TextColor="{StaticResource TextPrimary}"/>
                                                        <Label Text="{Binding Currency}" FontSize="10"
                                                               TextColor="{StaticResource TextMuted}"/>
                                                    </VerticalStackLayout>
                                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="End"
                                                                         VerticalOptions="Center" Spacing="2">
                                                        <Label Text="{Binding Balance, StringFormat='{0:F2}'}"
                                                               FontSize="14" FontAttributes="Bold"
                                                               TextColor="{StaticResource SuccessGreen}"
                                                               HorizontalOptions="End"/>
                                                        <Label Text="{Binding Role}" FontSize="10"
                                                               TextColor="{StaticResource TextMuted}"
                                                               HorizontalOptions="End"/>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Bottom Navigation -->
                    <Grid Grid.Row="1" BackgroundColor="White"
                          ColumnDefinitions="*,*,*,*"
                          Padding="0,8,0,12">
                        <BoxView Grid.ColumnSpan="4" Color="{StaticResource BorderColor}"
                                 HeightRequest="0.5" VerticalOptions="Start"/>
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                            <BoxView Color="{StaticResource BrandRed}" WidthRequest="4" HeightRequest="4"
                                     CornerRadius="2" HorizontalOptions="Center"/>
                            <Path Data="M3 9 L12 2 L21 9 L21 21 L5 21 Z"
                                  Stroke="{StaticResource Navy}" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="22" HeightRequest="22" Aspect="Uniform"
                                  HorizontalOptions="Center"/>
                            <Label Text="Начало" FontSize="10" TextColor="{StaticResource Navy}"
                                   FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                            <BoxView Color="Transparent" WidthRequest="4" HeightRequest="4" CornerRadius="2"/>
                            <Path Data="M12 4 L12 20 M4 12 L12 4 L20 12 M20 4 L20 20"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="22" HeightRequest="22" Aspect="Uniform"
                                  HorizontalOptions="Center">
                                <Path.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNavigateToTransfers"/>
                                </Path.GestureRecognizers>
                            </Path>
                            <Label Text="Преводи" FontSize="10" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNavigateToTransfers"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                            <BoxView Color="Transparent" WidthRequest="4" HeightRequest="4" CornerRadius="2"/>
                            <Path Data="M2 8 L22 8 M2 6 C2 6 2 18 2 18 C2 19 3 20 4 20 L20 20 C21 20 22 19 22 18 L22 6 C22 5 21 4 20 4 L4 4 C3 4 2 5 2 6 Z"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="22" HeightRequest="22" Aspect="Uniform"
                                  HorizontalOptions="Center">
                                <Path.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNavigateToPayments"/>
                                </Path.GestureRecognizers>
                            </Path>
                            <Label Text="Плащания" FontSize="10" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNavigateToPayments"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                            <BoxView Color="Transparent" WidthRequest="4" HeightRequest="4" CornerRadius="2"/>
                            <Path Data="M20 21 L20 19 C20 17 18 16 16 16 L8 16 C6 16 4 17 4 19 L4 21 M12 12 C14 12 16 10 16 8 C16 6 14 4 12 4 C10 4 8 6 8 8 C8 10 10 12 12 12 Z"
                                  Stroke="{StaticResource TextMuted}" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="22" HeightRequest="22" Aspect="Uniform"
                                  HorizontalOptions="Center">
                                <Path.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                                </Path.GestureRecognizers>
                            </Path>
                            <Label Text="Изход" FontSize="10" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLogoutClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
