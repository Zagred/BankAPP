<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.AccountsPage"
             Title="Accounts">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="My Accounts"
                           FontSize="30"
                           FontAttributes="Bold" />

                    <Label x:Name="WelcomeLabel"
                           Text="Welcome!"
                           FontSize="16"
                           FontAttributes="Italic"
                           Opacity="0.85" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Logout"
                        CornerRadius="12"
                        HeightRequest="42"
                        Clicked="OnLogoutClicked" />
            </Grid>

            <!-- ACCOUNTS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Text="Accounts"
                               FontSize="22"
                               FontAttributes="Bold" />

                        <Button Grid.Column="1"
                                Text="+ New"
                                CornerRadius="12"
                                HeightRequest="36"
                                Padding="8"
                                FontSize="12"
                                Clicked="OnCreateAccountClicked" />
                    </Grid>

                    <CollectionView x:Name="AccountsCollection"
                                    SelectionMode="None"
                                    HeightRequest="160">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="0,5" CornerRadius="14" BorderColor="LightGray">
                                    <VerticalStackLayout Spacing="4">

                                        <Label Text="{Binding Iban}"
                                               FontAttributes="Bold"
                                               FontSize="16" />

                                        <Label Text="{Binding Balance, StringFormat='Balance: {0:F2}'}" />

                                        <Label Text="{Binding Currency}"
                                               Opacity="0.7" />

                                        <Label Text="{Binding Role}"
                                               Opacity="0.7" />

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- SUMMARY -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <Frame Grid.Row="0" Grid.Column="0" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Balance" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="BalanceLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Income" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="IncomeLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Padding="16" CornerRadius="18" BorderColor="LightGray">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Expense" FontAttributes="Bold" FontSize="16"/>
                        <Label x:Name="ExpenseLabel" Text="0.00" FontSize="24"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- ACTIONS -->
            <Frame Padding="16" CornerRadius="18" BorderColor="LightGray">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Quick Actions"
                           FontSize="22"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
            Text="Transfer"
            CornerRadius="12"
            Clicked="OnTransferClicked" />

                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
            Text="Refresh"
            CornerRadius="12"
            Clicked="OnRefreshClicked" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>