<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Оригинални (запазени за Styles.xaml) -->
    <Color x:Key="Primary">#1A2E5A</Color>
    <Color x:Key="PrimaryDark">#0F1E3D</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#D32F2F</Color>
    <Color x:Key="SecondaryDarkText">#FFFFFF</Color>
    <Color x:Key="Tertiary">#15803D</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!-- ═══════════════════════════════
         UCB Design Tokens
    ═══════════════════════════════ -->
    <Color x:Key="NavyDeep">#0F1E3D</Color>
    <Color x:Key="Navy">#1A2E5A</Color>
    <Color x:Key="NavyMid">#243D6E</Color>
    <Color x:Key="BrandRed">#D32F2F</Color>
    <Color x:Key="BrandRedLight">#FFF5F5</Color>

    <Color x:Key="PageBg">#F0F2F7</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="InputBg">#F8F9FC</Color>

    <Color x:Key="TextPrimary">#1A1A2E</Color>
    <Color x:Key="TextMuted">#6B7280</Color>
    <Color x:Key="TextOnDark">#FFFFFF</Color>
    <Color x:Key="TextOnDarkMuted">#9CA3AF</Color>

    <Color x:Key="SuccessGreen">#15803D</Color>
    <Color x:Key="SuccessGreenBg">#F0FDF4</Color>
    <Color x:Key="WarningAmber">#92400E</Color>
    <Color x:Key="WarningAmberBg">#FFFBEB</Color>

    <Color x:Key="BorderColor">#DDE1EA</Color>
    <Color x:Key="BorderFocused">#1A2E5A</Color>

    <!-- ═══════════════════════════════
         Shared Styles
    ═══════════════════════════════ -->
    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="CharacterSpacing" Value="0.5"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="{StaticResource BorderColor}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="HeightRequest" Value="46"/>
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
        <Setter Property="StrokeThickness" Value="0.5"/>
        <Setter Property="Stroke" Value="{StaticResource BorderColor}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandRed}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="CornerRadius" Value="9"/>
    </Style>

    <Style x:Key="NavyBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Navy}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="CornerRadius" Value="9"/>
    </Style>

    <Style x:Key="OutlineBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource Navy}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
    </Style>

    <Style x:Key="GhostBtn" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
        <Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HeightRequest" Value="42"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderWidth" Value="0.5"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="LinkRed" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource BrandRed}"/>
    </Style>

    <Style x:Key="BalanceNumber" TargetType="Label">
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

    <Style x:Key="StatGreen" TargetType="Label">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource SuccessGreen}"/>
    </Style>

    <Style x:Key="StatRed" TargetType="Label">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource BrandRed}"/>
    </Style>

</ResourceDictionary>