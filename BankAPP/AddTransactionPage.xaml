<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.AddTransactionPage"
             Title="Add Transaction">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Add New Transaction"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Entry x:Name="AmountEntry"
                   Placeholder="Amount"
                   Keyboard="Numeric" />

            <Picker x:Name="TypePicker"
                    Title="Select Type"
                    SelectedIndexChanged="OnTypeChanged">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>income</x:String>
                        <x:String>expense</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Picker x:Name="CategoryPicker"
                    Title="Category" />

            <Entry x:Name="DescriptionEntry"
                   Placeholder="Description" />

            <DatePicker x:Name="TransactionDatePicker" />

            <Button Text="Save Transaction"
                    Clicked="OnSaveClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>