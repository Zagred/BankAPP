<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BankAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BankAPP"
    Title="BankAPP"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent x:Name="AccountsShell"
                      Route="Accounts"
                      Title="Accounts"
                      ContentTemplate="{DataTemplate local:AccountsPage}" />
        <ShellContent x:Name="TransfersShell"
                      Route="Transfers"
                      Title="Transfers"
                      ContentTemplate="{DataTemplate local:TransfersPage}" />
        <ShellContent x:Name="PaymentsShell"
                      Route="Payments"
                      Title="Payments"
                      ContentTemplate="{DataTemplate local:PaymentsPage}" />
        <ShellContent x:Name="AdminShell"
                      Route="Admin"
                      Title="Admin"
                      ContentTemplate="{DataTemplate local:AdminPage}" />
    </FlyoutItem>

</Shell>