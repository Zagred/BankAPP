<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BankAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BankAPP"
    Title="BankAPP">

    <TabBar>
        <Tab Title="Accounts">
            <ShellContent ContentTemplate="{DataTemplate local:AccountsPage}" />
        </Tab>
        <Tab Title="Transfers">
            <ShellContent ContentTemplate="{DataTemplate local:TransfersPage}" />
        </Tab>
        <Tab Title="Payments">
            <ShellContent ContentTemplate="{DataTemplate local:PaymentsPage}" />
        </Tab>
    </TabBar>

</Shell>
