<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.TransfersPage"
             Title="Transfers"
             BackgroundColor="{StaticResource PageBg}">

    <Grid RowDefinitions="52,*" ColumnDefinitions="220,*">

        <!-- SIDEBAR -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
              BackgroundColor="{StaticResource NavyDeep}"
              RowDefinitions="Auto,*,Auto">

            <HorizontalStackLayout Grid.Row="0" Spacing="10" Padding="20,22,20,20">
                <Border BackgroundColor="{StaticResource BrandRed}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                        WidthRequest="34" HeightRequest="34" Padding="0">
                    <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                          Stroke="White" StrokeThickness="1.6"
                          StrokeLineCap="Round" StrokeLineJoin="Round"
                          WidthRequest="18" HeightRequest="18" Aspect="Uniform"
                          HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                    <Label Text="BankApp" FontSize="15" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="ДИГИТАЛНО БАНКИРАНЕ" FontSize="8"
                           CharacterSpacing="0.6" TextColor="#55FFFFFF"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout Grid.Row="1" Padding="10,16" Spacing="2">
                <Label Text="ГЛАВНО МЕНЮ" FontSize="9" CharacterSpacing="0.8"
                       TextColor="#44FFFFFF" Margin="10,0,0,8" TextTransform="Uppercase"/>

                <Button Text="Сметки"
                        BackgroundColor="Transparent" TextColor="#77FFFFFF"
                        BorderWidth="0" CornerRadius="7" FontSize="13"
                        HeightRequest="42" HorizontalOptions="Fill"
                        Padding="10,0" Clicked="OnNavigateToAccounts"/>

                <Border BackgroundColor="{StaticResource BrandRed}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 7"
                        Padding="10,9">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Преводи" FontSize="13" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <Button Text="Плащания"
                        BackgroundColor="Transparent" TextColor="#77FFFFFF"
                        BorderWidth="0" CornerRadius="7" FontSize="13"
                        HeightRequest="42" HorizontalOptions="Fill"
                        Padding="10,0" Clicked="OnNavigateToPayments"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="2" Padding="10,14">
                <BoxView HeightRequest="0.5" Color="#33FFFFFF" Margin="0,0,0,12"/>
                <HorizontalStackLayout Spacing="10" Padding="10,0">
                    <Border BackgroundColor="{StaticResource BrandRed}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 16"
                            WidthRequest="32" HeightRequest="32">
                        <Label x:Name="AvatarLabel" Text="?"
                               FontSize="13" FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                        <Label x:Name="SidebarUsernameLabel" Text="—"
                               FontSize="12" FontAttributes="Bold" TextColor="#CCFFFFff"/>
                        <Label Text="Стандартен акаунт" FontSize="10" TextColor="#55FFFFFF"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- TOPBAR -->
        <Grid Grid.Row="0" Grid.Column="1"
              BackgroundColor="White"
              ColumnDefinitions="*,Auto,Auto"
              Padding="24,0" ColumnSpacing="10">
            <Label Grid.Column="0" Text="Преводи"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   VerticalOptions="Center"/>
            <Border Grid.Column="1"
                    BackgroundColor="#F3F4F6"
                    StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 6" Padding="12,5">
                <Label Text="17 май 2026" FontSize="11"
                       TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
            </Border>
            <Button Grid.Column="2" Text="Изход"
                    BackgroundColor="Transparent" TextColor="{StaticResource TextMuted}"
                    BorderColor="{StaticResource BorderColor}" BorderWidth="1"
                    CornerRadius="7" FontSize="12" FontAttributes="Bold"
                    HeightRequest="34" Padding="14,0"
                    Clicked="OnLogoutClicked"/>
        </Grid>

        <!-- MAIN CONTENT -->
        <ScrollView Grid.Row="1" Grid.Column="1">
            <VerticalStackLayout Padding="24" Spacing="14">

                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                    <!-- ФОРМА ЗА ПРЕВОД -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="14">

                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource Navy}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                        WidthRequest="32" HeightRequest="32">
                                    <Path Data="M12 4 L12 20 M4 12 L12 4 L20 12 M20 4 L20 20"
                                          Stroke="White" StrokeThickness="1.6"
                                          StrokeLineCap="Round" StrokeLineJoin="Round"
                                          WidthRequest="16" HeightRequest="16" Aspect="Uniform"
                                          HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Нов превод"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center" Margin="10,0,0,0"/>
                            </Grid>

                            <Label Text="ИЗХОДЯЩА СМЕТКА" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}" HeightRequest="46">
                                <Picker x:Name="FromAccountPicker"
                                        Title="Избери сметка"
                                        ItemDisplayBinding="{Binding DisplayText}"
                                        BackgroundColor="Transparent"
                                        FontSize="13"
                                        VerticalOptions="Center"/>
                            </Border>

                            <Label Text="IBAN НА ПОЛУЧАТЕЛЯ" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <Entry x:Name="ToIbanEntry"
                                       Placeholder="BG__ ____ ____ ____"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="СУМА (BGN)" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBorder}">
                                        <Entry x:Name="AmountEntry"
                                               Placeholder="0,00"
                                               PlaceholderColor="{StaticResource TextMuted}"
                                               TextColor="{StaticResource TextPrimary}"
                                               Keyboard="Numeric" FontSize="14"
                                               BackgroundColor="Transparent"
                                               VerticalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="ОСНОВАНИЕ" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBorder}">
                                        <Entry x:Name="DescriptionEntry"
                                               Placeholder="Описание"
                                               PlaceholderColor="{StaticResource TextMuted}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14" BackgroundColor="Transparent"
                                               VerticalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <Button Text="Изпрати превод"
                                    Style="{StaticResource PrimaryBtn}"
                                    Clicked="OnTransferClicked"
                                    Margin="0,4,0,0"/>

                            <Border BackgroundColor="#F8F9FC"
                                    StrokeThickness="0.5" Stroke="{StaticResource BorderColor}"
                                    StrokeShape="RoundRectangle 8" Padding="12,9">
                                <HorizontalStackLayout Spacing="8">
                                    <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                          Fill="{StaticResource SuccessGreen}"
                                          WidthRequest="14" HeightRequest="14"
                                          Aspect="Uniform" VerticalOptions="Center"/>
                                    <Label Text="Преводът е защитен и криптиран"
                                           FontSize="11" TextColor="{StaticResource TextMuted}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>

                    <!-- ИСТОРИЯ НА ПРЕВОДИТЕ -->
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="История на преводите"
                                       Style="{StaticResource SectionTitle}"/>
                            </Grid>

                            <CollectionView x:Name="TransfersCollection" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                BackgroundColor="#F8F9FC"
                                                StrokeThickness="0.5"
                                                Stroke="{StaticResource BorderColor}"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="14,12">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                                <!-- Икона -->
                                                <Border Grid.Column="0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 18"
                                                        WidthRequest="36" HeightRequest="36"
                                                        BackgroundColor="{StaticResource SuccessGreenBg}">
                                                    <Label Text="↓" FontSize="16" FontAttributes="Bold"
                                                           TextColor="{StaticResource SuccessGreen}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>
                                                </Border>

                                                <!-- Info -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="{Binding Description}"
                                                           FontSize="13" FontAttributes="Bold"
                                                           TextColor="{StaticResource TextPrimary}"/>
                                                    <Label Text="{Binding Status}"
                                                           FontSize="11"
                                                           TextColor="{StaticResource TextMuted}"/>
                                                    <Label Text="{Binding MovementDateTime, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                                           FontSize="10" TextColor="{StaticResource TextMuted}"/>
                                                </VerticalStackLayout>

                                                <!-- Сума -->
                                                <VerticalStackLayout Grid.Column="2"
                                                                     HorizontalOptions="End"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding AmountText}"
                                                           FontSize="14" FontAttributes="Bold"
                                                           HorizontalOptions="End">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label"
                                                                         Binding="{Binding IsExpense}"
                                                                         Value="True">
                                                                <Setter Property="TextColor" Value="{StaticResource BrandRed}"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label"
                                                                         Binding="{Binding IsExpense}"
                                                                         Value="False">
                                                                <Setter Property="TextColor" Value="{StaticResource SuccessGreen}"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                    <Label Text="{Binding Currency}"
                                                           FontSize="10"
                                                           TextColor="{StaticResource TextMuted}"
                                                           HorizontalOptions="End"/>
                                                </VerticalStackLayout>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>