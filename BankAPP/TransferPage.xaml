<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BankAPP.TransferPage"
             Title="Нов превод"
             BackgroundColor="{StaticResource PageBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid BackgroundColor="{StaticResource NavyDeep}" Padding="20,48,20,28">
                <Ellipse Fill="#07FFFFFF" WidthRequest="160" HeightRequest="160"
                         HorizontalOptions="End" VerticalOptions="Start" Margin="0,-30,-30,0"/>
                <VerticalStackLayout Spacing="6">
                    <HorizontalStackLayout Spacing="10" Margin="0,0,0,20">
                        <Border BackgroundColor="{StaticResource BrandRed}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="28" HeightRequest="28" Padding="0">
                            <Path Data="M11.5 1L2 6v2h19V6M16 10v7M12 10v7M8 10v7M2 19h19M2 22h19"
                                  Stroke="White" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeLineJoin="Round"
                                  WidthRequest="14" HeightRequest="14" Aspect="Uniform"
                                  HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="BankApp" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                    </HorizontalStackLayout>
                    <Label Text="Нов превод" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Изпрати пари бързо и сигурно"
                           FontSize="13" TextColor="#77FFFFFF"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Form card -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="24,28,24,40" Margin="0,-16,0,0">
                <VerticalStackLayout Spacing="0">

                    <Label Text="ИЗХОДЯЩА СМЕТКА" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" HeightRequest="46" Margin="0,0,0,16">
                        <Picker x:Name="FromAccountPicker"
                                Title="Избери сметка"
                                ItemDisplayBinding="{Binding DisplayText}"
                                BackgroundColor="Transparent" FontSize="13"
                                VerticalOptions="Center"/>
                    </Border>

                    <Label Text="IBAN НА ПОЛУЧАТЕЛЯ" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                        <Entry x:Name="ToIbanEntry"
                               Placeholder="BG__ ____ ____ ____"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="14" BackgroundColor="Transparent"
                               ClearButtonVisibility="WhileEditing"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Text="СУМА (BGN)" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                        <Entry x:Name="AmountEntry"
                               Placeholder="0,00"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               Keyboard="Numeric" FontSize="14"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Text="ОСНОВАНИЕ" Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource InputBorder}" Margin="0,0,0,28">
                        <Entry x:Name="DescriptionEntry"
                               Placeholder="Описание за превода"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="14" BackgroundColor="Transparent"
                               ReturnType="Done"
                               VerticalOptions="Center"/>
                    </Border>

                    <Button Text="Изпрати превод"
                            Style="{StaticResource PrimaryBtn}"
                            Clicked="OnTransferClicked"/>

                    <Border BackgroundColor="#F8F9FC" StrokeThickness="0.5"
                            Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 8"
                            Padding="14,11" Margin="0,16,0,0">
                        <HorizontalStackLayout Spacing="9">
                            <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                  Fill="{StaticResource SuccessGreen}"
                                  WidthRequest="16" HeightRequest="16"
                                  Aspect="Uniform" VerticalOptions="Center"/>
                            <Label Text="Преводът е защитен и криптиран"
                                   FontSize="11" TextColor="{StaticResource TextMuted}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>