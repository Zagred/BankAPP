@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject ApiAuthService AuthService

<div class="app-shell">

    @if (showSidebar)
    {
        <aside class="ucb-sidebar">
            <div class="sb-logo">
                <div class="sb-logo-mark">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11.5 1L2 6v2h19V6z" />
                        <line x1="16" y1="10" x2="16" y2="17" />
                        <line x1="12" y1="10" x2="12" y2="17" />
                        <line x1="8" y1="10" x2="8" y2="17" />
                        <line x1="2" y1="19" x2="22" y2="19" />
                        <line x1="2" y1="22" x2="22" y2="22" />
                    </svg>
                </div>
                <div>
                    <div class="sb-logo-name">BankApp</div>
                    <div class="sb-logo-sub">ДИГИТАЛНО БАНКИРАНЕ</div>
                </div>
            </div>

            <nav class="sb-nav">
                <div class="sb-section-label">ГЛАВНО МЕНЮ</div>
                <NavLink class="sb-item" href="/accounts" Match="NavLinkMatch.All">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    Сметки
                </NavLink>
                <NavLink class="sb-item" href="/transfers">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="4" x2="12" y2="20" />
                        <polyline points="4 12 12 4 20 12" />
                        <line x1="20" y1="4" x2="20" y2="20" />
                    </svg>
                    Преводи
                </NavLink>
                <NavLink class="sb-item" href="/payments">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                        <line x1="1" y1="10" x2="23" y2="10" />
                    </svg>
                    Плащания
                </NavLink>

                @if (isAdmin)
                {
                    <div class="sb-section-label" style="margin-top:16px;">АДМИНИСТРАЦИЯ</div>
                    <NavLink class="sb-item" href="/admin">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                        Адм. панел
                    </NavLink>
                }
            </nav>

            <div class="sb-footer">
                <div class="sb-divider"></div>
                <div class="sb-user">
                    <div class="sb-avatar">@userInitial</div>
                    <div>
                        <div class="sb-username">@username</div>
                        <div class="sb-role">@(isAdmin ? "Администратор" : "Стандартен акаунт")</div>
                    </div>
                </div>
            </div>
        </aside>
    }

    <div class="ucb-main @(showSidebar ? "" : "no-sidebar")">
        @if (showSidebar)
        {
            <header class="ucb-topbar">
                <div class="topbar-title">@pageTitle</div>
                <div class="topbar-right">
                    <span class="topbar-date">@DateTime.Now.ToString("dd MMMM yyyy")</span>
                    <button class="btn-logout" @onclick="HandleLogout">Изход</button>
                </div>
            </header>
        }

        <div class="ucb-content @(showSidebar ? "" : "full-height")">
            @Body
        </div>
    </div>

</div>

<div id="blazor-error-ui" data-nosnippet>
    Възникна грешка.
    <a href="." class="reload">Презареди</a>
    <span class="dismiss">✕</span>
</div>

@code {
    private bool showSidebar = true;
    private bool isAdmin = false;
    private string username = "";
    private string userInitial = "?";
    private string pageTitle = "BankApp";

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var currentPath = Navigation.Uri;

        showSidebar = !currentPath.Contains("/login") &&
                      !currentPath.Contains("/register");

        isAdmin = AuthService.IsAdmin;
        username = AuthService.CurrentUser?.User.Username ?? "";
        userInitial = username.Length > 0 ? username[0].ToString().ToUpper() : "?";

        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        showSidebar = !e.Location.Contains("/login") &&
                      !e.Location.Contains("/register");

        isAdmin = AuthService.IsAdmin;
        username = AuthService.CurrentUser?.User.Username ?? "";
        userInitial = username.Length > 0 ? username[0].ToString().ToUpper() : "?";
        pageTitle = GetPageTitle(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private static string GetPageTitle(string url) => url switch
    {
        var u when u.Contains("/accounts") => "Моите сметки",
        var u when u.Contains("/transfers") => "Преводи",
        var u when u.Contains("/payments") => "Плащания",
        var u when u.Contains("/admin") => "Административен панел",
        _ => "BankApp"
    };

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}